generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeRole {
  ADMIN
  USER
}

enum EmployeeStatus {
  IN_EXPERIENCE
  HIRED
  FIRED
}

enum ProposalStatus {
  UNDER_ANALYSIS
  ON_VOTE
  APPROVED
  REJECTED
}

enum VotingResult {
  APPROVED
  REJECTED
}

model EmployeeInfo {
  id             String          @id @default(uuid()) @db.Uuid
  first_name     String          @db.VarChar(125)
  last_name      String          @db.VarChar(125)
  username       String          @db.VarChar(45)
  email          String          @db.VarChar(250)
  password       String          @db.VarChar(125)
  phone          String          @db.VarChar(15)
  position       String          @db.VarChar(125)
  role           EmployeeRole
  status         EmployeeStatus
  
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt()

  Proposal       Proposal[]
  ProposalHype   ProposalHype[]
  EmployeeVote   EmployeeVote[]

  @@map("employee_info")
}

model Proposal {
  id             String          @id @default(uuid()) @db.Uuid
  employee_id    String          @db.Uuid
  proposal       String          @db.VarChar(125)
  description    String          @db.VarChar(700)
  status         ProposalStatus
  
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt()

  employee       EmployeeInfo    @relation(fields: [employee_id], references: [id])

  ProposalHype   ProposalHype[]
  ProposalVoting ProposalVoting[]
  EmployeeVote   EmployeeVote[]

  @@map("proposal")
}

model ProposalHype {
  id             String          @id @default(uuid()) @db.Uuid
  proposal_id    String          @db.Uuid
  employee_id    String          @db.Uuid
  comment        String          @db.VarChar(280)
  
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt()

  proposal       Proposal        @relation(fields: [proposal_id], references: [id])
  employee       EmployeeInfo    @relation(fields: [employee_id], references: [id])

  @@map("proposal_hype")
}

model ProposalVoting {
  id             String          @id @default(uuid()) @db.Uuid
  proposal_id    String          @db.Uuid
  expires_in     String          @db.VarChar()
  in_favour      Int             @db.Integer()
  against        Int             @db.Integer()
  result         VotingResult
  
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt()

  proposal       Proposal        @relation(fields: [proposal_id], references: [id])

  @@map("proposal_voting")
}

model EmployeeVote {
  id             String          @id @default(uuid()) @db.Uuid
  proposal_id    String          @db.Uuid()
  employee_id    String          @db.Uuid()
  voted          Boolean         @db.Boolean()
  
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt()

  proposal       Proposal        @relation(fields: [proposal_id], references: [id])
  employee       EmployeeInfo    @relation(fields: [employee_id], references: [id])

  @@map("employee_vote")
}
