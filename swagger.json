{
  "openapi": "3.0.0",
  "info": {
    "title": "MIAU Backend API Documentation",
    "description": "Back-end API to improve shareable environments",
    "contact": {
      "name": "Rafael Ribeiro",
      "url": "https://www.wophi.be/miau/support",
      "email": "miau@wophi.be"
    },
    "version": "0.0.1"
  },
  "paths": {
    "/user/admin": {
      "post": {
        "summary": "Create a new admin user",
        "description": "Route to register new admin users",
        "tags": ["User"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUp"
              },
              "examples": {
                "example1": {
                  "summary": "Example of a valid user registration",
                  "value": {
                    "firstName": "John",
                    "lastName": "Doe",
                    "username": "johndoe",
                    "phone": "1234567890",
                    "email": "johndoe@example.com",
                    "password": "Password123",
                    "passwordConfirmation": "Password123",
                    "position": "Back-end developer",
                    "status": "IN_EXPERIENCE",
                    "signupToken": "admin_signup_token"
                  }
                },
                "example2": {
                  "summary": "Example of a valid user registration",
                  "value": {
                    "firstName": "John",
                    "lastName": "Doe",
                    "username": "johndoe",
                    "phone": "1234567890",
                    "email": "johndoe@example.com",
                    "password": "Password123",
                    "passwordConfirmation": "Password123",
                    "position": "Back-end developer",
                    "status": "HIRED",
                    "signupToken": "admin_signup_token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                },
                "example": {
                  "accessToken": "eyJhbGciOiJ.eyJzdW5MDIyfQ.SflKxwk6yJV_adQssw5c"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "example1": {
                    "summary": "Dto validation",
                    "value": {
                      "error": {
                        "message": [
                          "One or more fields are missing or invalid"
                        ],
                        "code": "bad.request",
                        "status": true
                      },
                      "data": {}
                    }
                  },
                  "example2": {
                    "summary": "Missing or invalid field",
                    "value": {
                      "error": {
                        "message": "missing or invalid signup token",
                        "code": "user-service.createAdminUser",
                        "status": true
                      },
                      "data": {}
                    }
                  },
                  "example3": {
                    "summary": "Invalid password",
                    "value": {
                      "error": {
                        "message": "passwords do not match",
                        "code": "user-service.createAdminUser",
                        "status": true
                      },
                      "data": {}
                    }
                  },
                  "example4": {
                    "summary": "Field already taken",
                    "value": {
                      "error": {
                        "message": "[ 'field' ] already in use",
                        "code": "user-repository.createUser",
                        "status": true
                      },
                      "data": {}
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "message": "user not created",
                    "code": "user-repository.createUser",
                    "status": true
                  },
                  "data": {}
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemas": {}
  }
}
